{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyCLIProxyAPI",
  "version": "0.2.0",
  "identifier": "com.cpa.gui",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "EasyCLIProxyAPI",
        "width": 1200,
        "height": 810,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
